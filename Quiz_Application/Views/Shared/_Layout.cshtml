@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GAIL (India) Limited</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Quiz" asp-action="All">
                    <img src="~/images/gail-logo.png" alt="GAIL Logo" style="height: 38px; margin-right: 12px;" />
                    <span>GAIL (India) Limited</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        @if (HttpContextAccessor.HttpContext?.Session?.GetString("IsAdmin") == "true" || User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" asp-controller="Admin" asp-action="Index">🛠️ Admin Panel</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">🚪 Logout</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container pb-5">
        @RenderBody()
    </main>

    <footer class="text-center mt-auto">
        <div class="container">
            <span>&copy; @DateTime.Now.Year GAIL (India) Limited. All rights reserved.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
