@{
    ViewData["Title"] = "Quiz Results";
}

<div class="container py-5">
    <div class="card-premium results-card p-5" style="max-width: 600px; margin: 0 auto; text-align: center;">
        <span class="badge mb-3 px-3 py-2" style="background-color: var(--brand-success-light); color: var(--brand-success); font-weight: 700; border-radius: var(--radius-sm);">🎉 Assessment Completed</span>
        <h2 class="fw-extrabold mb-1" style="font-size: 2rem; color: var(--text-main); letter-spacing: -0.03em;">Quiz Results</h2>
        <p class="text-muted mb-4">Your score has been graded automatically.</p>

        <!-- 🏆 Interactive Grade Ring -->
        <div class="results-circle shadow-sm" style="width: 140px; height: 140px; border-radius: 50%; background: var(--brand-primary-light); border: 4px solid var(--brand-primary); display: flex; align-items: center; justify-content: center; margin: 20px auto 30px auto;">
            <div class="results-score" style="font-size: 2.25rem; font-weight: 800; color: var(--brand-primary);">
                @ViewBag.Score<span style="font-size: 1.25rem; font-weight: 600; color: var(--text-muted); margin: 0 4px;">/</span>@ViewBag.TotalScore
            </div>
        </div>

        <div class="row g-3 text-start mt-4 mb-5" style="max-width: 420px; margin: 0 auto;">
            <div class="col-12 border-bottom pb-2 d-flex justify-content-between">
                <span class="text-muted fw-bold">📅 Start Time</span>
                <span class="fw-semibold text-light">@(ViewBag.StartTime ?? "N/A")</span>
            </div>
            <div class="col-12 border-bottom pb-2 d-flex justify-content-between">
                <span class="text-muted fw-bold">⏰ End Time</span>
                <span class="fw-semibold text-light">@(ViewBag.EndTime ?? "N/A")</span>
            </div>
            <div class="col-12 border-bottom pb-2 d-flex justify-content-between">
                <span class="text-muted fw-bold">⌛ Duration</span>
                <span class="fw-bold text-primary" style="color: var(--brand-primary) !important;">@(ViewBag.Duration ?? "N/A")</span>
            </div>
        </div>

        <a asp-controller="Quiz" asp-action="All" class="btn-premium px-5 py-3 text-decoration-none d-inline-block" style="background: var(--brand-primary); color: white; border-radius: 12px; font-weight: 600;">📚 Back to Quizzes</a>
    </div>
</div>
