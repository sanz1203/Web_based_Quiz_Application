@model Quiz_Application.Models.ViewModels.QuizViewModel

@{
    ViewData["Title"] = "Attempt Quiz";
    int quizDurationMinutes = ViewBag.QuizDurationMinutes ?? 30; // default to 30 if not set
}

<style>
    body {
        background-color: #fefefe;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .quiz-heading {
        color: #1a237e;
        font-weight: bold;
    }

    .quiz-card {
        background-color: #f5f7fa;
        border-left: 5px solid #1a237e;
        border-radius: 10px;
    }

    .option-box {
        background-color: #e8f0fe;
        border-radius: 6px;
        padding: 12px 16px;
        margin-bottom: 10px;
        cursor: pointer;
        position: relative;
        transition: all 0.2s ease-in-out;
    }

        .option-box:hover {
            background-color: #d7e3fc;
        }

        .option-box input[type="radio"] {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            accent-color: #1a237e;
            width: 18px;
            height: 18px;
        }

    .option-label {
        display: block;
        padding-left: 36px;
        font-size: 16px;
        color: #333;
    }

    .submit-btn {
        background-color: #1a237e;
        border: none;
        color: white;
        padding: 10px 25px;
        font-size: 18px;
        border-radius: 5px;
    }

        .submit-btn:hover {
            background-color: #0d1b5f;
        }

    .timer-box {
        text-align: center;
        margin-bottom: 20px;
        font-size: 20px;
        font-weight: bold;
        color: #d32f2f;
    }
</style>

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="quiz-heading">📝 Attempt Quiz</h2>
        <p class="text-muted">Answer the following questions carefully before time runs out.</p>
    </div>

    <!-- ⏱️ Timer Display -->
    <div class="timer-box">
        Time Remaining: <span id="timer">--:--</span>
    </div>

    <form asp-action="Submit" method="post" id="quizForm">
        <input type="hidden" name="quizId" value="@Model.QuizId" />

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var question = Model.Questions[i];

            <div class="card quiz-card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-dark">Q@(i + 1): @question.Text</h5>

                    @foreach (var option in question.Options)
                    {
                        var inputId = $"question_{i}_option_{option.Value}";
                        <label class="option-box" for="@inputId">
                            <input type="radio"
                                   id="@inputId"
                                   name="userAnswers[@question.Id]"
                                   value="@option.Value"
                                   required />
                            <span class="option-label">@option.Text</span>
                        </label>
                    }
                </div>
            </div>
        }

        <div class="text-center">
            <button type="submit" class="submit-btn">Submit ✅</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Set duration from server
        const totalSeconds = @(quizDurationMinutes) * 60;
        let secondsLeft = totalSeconds;

        function updateTimer() {
            const minutes = Math.floor(secondsLeft / 60);
            const seconds = secondsLeft % 60;
            document.getElementById("timer").innerText = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;

            if (secondsLeft <= 0) {
                clearInterval(timerInterval);
                alert("⏱️ Time is up! Submitting your quiz...");
                document.getElementById("quizForm").submit();
            }

            secondsLeft--;
        }

        const timerInterval = setInterval(updateTimer, 1000);
        updateTimer(); // run immediately
    </script>
}

