@model Quiz_Application.Models.ViewModels.QuizViewModel

@{
    ViewBag.Title = "Take Quiz";
}

@if (Model.Questions.Any())
{
    <form asp-controller="Quiz" asp-action="Submit" method="post">
        <div class="quiz-container">
            <h2 class="quiz-title">Guess the Capital – (@Model.Questions.Count questions)</h2>

            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                <div class="question-card mb-4">
                    <h4 class="question-text">Q@(i + 1). @Model.Questions[i].Text</h4>

                    @foreach (var option in Model.Questions[i].Options)
                    {
                        <div class="form-check">
                            <input type="radio"
                                   class="form-check-input"
                                   name="userAnswers[@i]"
                                   value="@option.Value"
                                   id="option_@option.Value"
                                   required />
                            <label class="form-check-label" for="option_@option.Value">
                                @option.Text
                            </label>
                        </div>
                    }
                </div>
            }

            <button type="submit" class="btn btn-primary submit-btn">Submit Quiz</button>
        </div>
    </form>
}
else
{
    <p>No questions available.</p>
}
