@model List<Quiz_Application.Models.Entities.Quiz>

@{
    ViewData["Title"] = "Available Quizzes";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-extrabold text-primary" style="font-size: 2.5rem; letter-spacing: -0.03em; color: var(--brand-primary);">Available Quizzes</h2>
        <p class="text-muted">Select an active assessment below to begin.</p>
    </div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var quiz in Model)
            {
                <div class="col">
                    <div class="card-premium h-100 d-flex flex-column justify-content-between">
                        <div>
                            <span class="badge mb-3 px-3 py-2" style="background-color: var(--brand-primary-light); color: var(--brand-primary); font-weight: 700; border-radius: var(--radius-sm);">📝 Active Assessment</span>
                            <h3 class="fw-bold mb-2" style="font-size: 1.35rem; color: var(--text-main);">@quiz.Title</h3>
                            <p class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">@quiz.Description</p>
                        </div>
                        
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-4 text-muted" style="font-size: 0.875rem; font-weight: 550;">
                                <span>📅 Start: @quiz.StartTime.ToString("dd MMM yyyy, hh:mm tt")</span>
                                <span class="mx-1">•</span>
                                <span>⌛ End: @quiz.EndTime.ToString("dd MMM yyyy, hh:mm tt")</span>
                            </div>
                            
                            <a class="btn-premium w-100 text-center d-block text-decoration-none" asp-action="Attempt" asp-route-id="@quiz.Id">Start Quiz</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card-premium text-center py-5">
            <span style="font-size: 3rem;">📭</span>
            <h4 class="mt-3 fw-bold">No Quizzes Available</h4>
            <p class="text-muted mb-0">Check back later for newly published assignments.</p>
        </div>
    }
</div>
