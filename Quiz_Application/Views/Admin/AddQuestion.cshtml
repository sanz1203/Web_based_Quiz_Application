@{
    ViewData["Title"] = "Add Question";
    var quizId = ViewBag.QuizId;
}

<div class="container mt-5">
    <h2 class="mb-4 text-center">➕ Add Question</h2>

    <!-- ✅ Manual Add Question Form -->
    <form asp-action="AddQuestion" method="post" class="border p-4 rounded shadow-sm bg-light mb-4">
        <input type="hidden" name="quizId" value="@quizId" />

        <div class="mb-3">
            <label class="form-label fw-bold">Question Text</label>
            <input class="form-control" name="Text" placeholder="Enter your question here..." required />
        </div>

        @for (int i = 0; i < 4; i++)
        {
            <div class="mb-2">
                <label class="form-label">Option @(i + 1)</label>
                <input class="form-control" name="Options[@i]" placeholder="Enter option @(i + 1)" required />
            </div>
        }

        <div class="mb-4">
            <label class="form-label fw-bold">Correct Option</label>
            <select class="form-select" name="CorrectOptionIndex" required>
                <option value="" disabled selected>-- Select Correct Option --</option>
                <option value="0">Option 1</option>
                <option value="1">Option 2</option>
                <option value="2">Option 3</option>
                <option value="3">Option 4</option>
            </select>
        </div>

        <div class="d-flex justify-content-between">
            <button class="btn btn-primary" type="submit">✅ Add Question</button>
            <a asp-action="ManageQuestions" asp-route-quizId="@quizId" class="btn btn-outline-secondary">✏️ Edit Questions</a>
        </div>
    </form>

    <!-- ✅ Excel Upload Option -->
    <div class="border p-4 rounded shadow-sm bg-light">
        <h4 class="mb-3">📄 Or Upload Questions via Excel</h4>
        <form asp-action="UploadExcel" asp-controller="Admin" method="post" enctype="multipart/form-data">
            <input type="hidden" name="quizId" value="@quizId" />

            <div class="mb-3">
                <label for="excelFile" class="form-label">Select Excel File (.xlsx)</label>
                <input type="file" name="excelFile" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-info">⬆️ Upload Excel</button>
        </form>
    </div>
</div>
